# Copy to `.env` in this directory. Dev / build / preview will not run without `.env`
# and a non-empty API base URL (see `scripts/assert-local-env.mjs`).

# REQUIRED: Browser-visible API prefix (scheme + host + `/api`), no trailing slash.
# Examples:
# - Direct Nest: http://127.0.0.1:8080/api
# - Same origin as SPA (if you proxy `/api`): http://127.0.0.1:3000/api
VITE_API_BASE_URL=
