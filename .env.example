# Examples:
# - Direct Nest: http://127.0.0.1:8080/api
# - Same origin as SPA (if you proxy `/api`): http://127.0.0.1:3000/api
VITE_API_BASE_URL=

# Same as system-backend: gates `/dev/api-test` in the built SPA.
# Docker Compose defaults NODE_ENV=development at build time unless overridden.
NODE_ENV=development
