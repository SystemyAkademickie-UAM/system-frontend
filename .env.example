# API base URL for browser requests: origin + global prefix (e.g. /api), no trailing slash.
# Leave unset in local dev to default to http://127.0.0.1:8080/api.
# For `docker build`, pass the URL the browser will use, e.g.:
#   docker build --build-arg VITE_API_BASE_URL=http://127.0.0.1:8080/api .
# VITE_API_BASE_URL=
